# Secure Billing Infrastructure - Environment Configuration

# ============================================================================
# CRITICAL SECURITY: DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Add .env to .gitignore before committing
# ============================================================================

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=creative_web_solutions
DB_POOL_SIZE=10

# Encryption Keys (AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (256 bits)
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here_must_be_256_bit_aes

# Session/JWT Configuration
JWT_SECRET=your_256_bit_random_jwt_secret_here_must_be_very_secure
JWT_EXPIRY=7d
SESSION_TIMEOUT=3600000

# Payment Processor Configuration
# PRIMARY: Stripe (https://stripe.com)

# Stripe Test Mode (Development)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_4eC39HqLyjWDarhtT657
STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefg
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890

# Stripe Live Mode (Production) - only set when ready
# STRIPE_SECRET_KEY_LIVE=sk_live_your_production_secret
# STRIPE_PUBLIC_KEY_LIVE=pk_live_your_production_public
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_live_your_webhook_secret

# Stripe Configuration
STRIPE_API_VERSION=2023-10-16
STRIPE_DESCRIPTION_PREFIX=Creative Web Solutions

# Alternative Processors (Secondary - optional)
# Uncomment if using Square or PayPal as fallback

# Square Configuration
SQUARE_ACCESS_TOKEN=sq_secret_your_token_here
SQUARE_LOCATION_ID=your_location_id
SQUARE_WEBHOOK_SIGNATURE_KEY=your_signature_key

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

# Security Configuration
HTTPS_ENABLED=true
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RATE_LIMIT_PAYMENTS=5,300s
RATE_LIMIT_LOGIN=10,900s

# Audit Logging
AUDIT_LOG_LEVEL=info
AUDIT_LOG_FILE=/var/log/billing/audit.log
AUDIT_LOG_RETENTION_DAYS=90

# Environment
NODE_ENV=production
LOG_LEVEL=info

# PCI DSS Compliance
PCI_DSS_VERSION=3.2.1
TOKENIZATION_ENABLED=true
ENCRYPTION_AT_REST=true
ENCRYPTION_IN_TRANSIT=true

# Monitoring & Alerts
SENTRY_DSN=https://your_sentry_project_key@sentry.io/your_project_id
ALERT_EMAIL=security@yourdomain.com
ALERT_PHONE=

# Backup Configuration
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_64_hex_chars
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# Do NOT modify values below without security team approval
# ============================================================================
SENSITIVE_DATA_REDACTED=true
RAW_CARD_DATA_BLOCKED=true
CVV_STORAGE_BLOCKED=true
SSL_VERIFY=true
